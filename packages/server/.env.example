# Database
DATABASE_URL=postgresql+asyncpg://agentflow:agentflow123@localhost:5432/agentflow

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1/
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=1.0
LLM_TOP_P=0.8
LLM_MAX_TOKENS=5000
LLM_TIMEOUT=120.0

# Match / Assembly
ASSEMBLY_CONFIDENCE_THRESHOLD=0.7

# CodeBuddy
CODEBUDDY_PATH=codebuddy
WORKSPACE_DIR=./workspace

# Extensions
EXTENSIONS_DIR=

# App
DEBUG=true
APP_NAME=AgentFlow
API_PREFIX=/api
LOG_LEVEL=INFO
LOG_DIR=logs
